#!/usr/bin/env bash
# Guard: <what it catches, in one line>.
# <Why it matters — the scar: what shipped/broke the day this became a rule.>
#
# Contract (that's ALL there is to it):
#   env  PROOFGATE_BASE   — git ref to diff against (always set by the runner)
#   env  PROOFGATE_CFG    — path to proofgate.json (may not exist)
#   env  PROOFGATE_LIB    — path to lib.sh (optional; source it for the helpers below)
#   env  PROOFGATE_STRICT — "1" when --strict (rarely needed; the runner promotes warns)
#   exit 0 = pass · 1 = FAIL (blocks the gate) · 2 = WARN (must be justified)
#   print ONE ✅/⚠️/❌ line (the runner streams your output verbatim)
#
# Rename to NN-name.sh (NN orders execution) and drop it in guards.d/ — done.
#
# TWO CONVENTIONS keep the gate from flagging its OWN source (guard files literally
# contain the sin patterns), and give consumers escape hatches:
#   - end pattern-bearing lines with a `proofgate-allow` comment;
#   - exclude the gate's files with "${PG_SELF_EXCLUDE[@]}" — or just use pg_scan,
#     which applies both self-exclusion AND per-finding .proofgateignore suppression.
set -uo pipefail
# shellcheck source=/dev/null
. "${PROOFGATE_LIB:-$(dirname "$0")/../lib.sh}" 2>/dev/null || true
BASE="${PROOFGATE_BASE:?}"

# The easy path: pg_scan prints the file of each added line matching the regex,
# after self-exclusion + proofgate-allow + .proofgateignore. Count and decide.
n="$(pg_scan my-guard 'YOUR_PATTERN_HERE' | pg_count)"   # proofgate-allow

if [ "${n:-0}" -gt 0 ]; then
  echo "⚠️  my-guard: $n added line(s) look like <the problem> — <what to do>"
  exit 2
fi
echo "✅ my-guard: clean"
exit 0

# ── Without the lib (portable, no helpers): the raw contract still works ───────
#   HITS=$(git diff "$BASE"..HEAD | grep -E '^\+' | grep -Ec 'YOUR_PATTERN_HERE')
#   [ "${HITS:-0}" -gt 0 ] && { echo "⚠️ ..."; exit 2; }; echo "✅ ..."; exit 0
